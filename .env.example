# Local Database Configuration
DB_LOCAL_NAME="auroraho_aurorahotelplaza.com"
DB_LOCAL_USER="root"
DB_LOCAL_PASSWORD=""
DB_LOCAL_HOST="127.0.0.1:3306"

# Production Database Configuration
DB_HOST_NAME="auroraho_aurorahotelplaza.com"
DB_HOST_USER="auroraho_username_here"
DB_HOST_PASSWORD="production_password_here"
DB_HOST_HOST="localhost:3306"

# AI Configuration
# Providers: gemini, qwen
AI_PROVIDER="gemini"
AI_MODEL="gemini-2.0-flash"
GEMINI_API_KEYS="key1,key2"

# Qwen AI (Alibaba DashScope) Configuration
# Model example: qwen-max, qwen-plus, qwen-turbo, qwen-long
QWEN_API_KEY="your_qwen_api_key_here"
QWEN_MODEL="qwen-max"

# Email SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"
SMTP_ENCRYPTION="tls"
SMTP_SECURE="tls"
SMTP_AUTH=true

# Email Settings
FROM_EMAIL="your_email@gmail.com"
FROM_NAME="Aurora Hotel Plaza"
REPLY_TO_EMAIL="your_email@gmail.com"
