# ============================================
# Aurora Hotel Plaza - Stable Subdirectory Config
# For: /2025/
# ============================================

# Disable MultiViews to avoid conflicts with our rules
Options -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /2025/

    # ── 1. SEO Friendly URL Mapping ──────────
    # Map friendly URL back to .php (Internal)
    RewriteRule ^trang-chu$ index.php [L,QSA]
    RewriteRule ^phong-nghi$ rooms.php [L,QSA]
    RewriteRule ^can-ho$ apartments.php [L,QSA]
    RewriteRule ^tin-tuc$ blog.php [L,QSA]
    RewriteRule ^dich-vu$ services.php [L,QSA]
    RewriteRule ^gioi-thieu$ about.php [L,QSA]
    RewriteRule ^lien-he$ contact.php [L,QSA]
    RewriteRule ^kham-pha$ explore.php [L,QSA]
    RewriteRule ^thu-vien-anh$ gallery.php [L,QSA]

    # Detailed mappings
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^phong-nghi/([^/]+)$ room-detail.php?slug=$1 [L,QSA]
    
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^can-ho/([^/]+)$ apartment-detail.php?slug=$1 [L,QSA]
    
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^tin-tuc/([^/]+)$ blog-detail.php?slug=$1 [L,QSA]
    
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^dich-vu/([^/]+)$ service-detail.php?slug=$1 [L,QSA]

    # ── 2. Hide .php from URL (Redirect) ──────────
    # Only if this is the initial request (not internal rewrite)
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} \.php$
    # Strip .php and redirect. 
    # Since RewriteBase is /2025/, we redirect to relative path
    RewriteRule ^(.+)\.php$ $1 [R=301,L,NC]

    # ── 3. Internal rewrite for extensionless URLs ──
    # If file.php exists and it's not a directory
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*?)/?$ $1.php [L]

</IfModule>

# Basic Security
<FilesMatch "^(\.env|\.git|composer\.(json|lock)|package\.json)$">
    Require all denied
</FilesMatch>
