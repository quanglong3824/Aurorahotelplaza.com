# ============================================
# AURORA HOTEL PLAZA - Environment Variables
# ============================================
# Copy file này thành .env và điền giá trị thực
# File .env nên đặt NGOÀI public_html để bảo mật
# Ví dụ: /home/user/config/.env
# ============================================

# --------------------------------------------
# AI PROVIDER CONFIGURATION
# --------------------------------------------
# Chọn provider: 'alibaba' hoặc 'gemini'
# Mặc định: alibaba
AI_PROVIDER=alibaba

# --------------------------------------------
# ALIBABA DASHSCOPE API (China)
# --------------------------------------------
# API Key từ Alibaba Cloud DashScope (China)
# Đăng ký tại: https://dashscope.console.aliyun.com/
ALIBABA_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Có thể dùng nhiều key (phân cách bằng dấu phẩy)
# ALIBABA_API_KEYS=sk-key1,sk-key2,sk-key3

# API URL (China - Native DashScope)
ALIBABA_API_URL=https://dashscope.aliyuncs.com/api/v1

# Models khả dụng:
# - qwen-turbo   (nhanh, rẻ)
# - qwen-plus    (cân bằng, recommended)
# - qwen-max     (mạnh nhất)
# - qwen-long    (context dài)
ALIBABA_MODEL=qwen-plus

# --------------------------------------------
# GOOGLE GEMINI API (Tùy chọn)
# --------------------------------------------
# API Key từ Google AI Studio
# Đăng ký tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Có thể dùng nhiều key (phân cách bằng dấu phẩy)
# GEMINI_API_KEYS=AIza-key1,AIza-key2,AIza-key3

# Model (mặc định: gemini-2.0-flash)
# AI_MODEL=gemini-2.0-flash

# --------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------
DB_HOST=localhost
DB_NAME=auroraho_aurorahotelplaza
DB_USER=your_db_user
DB_PASS=your_db_password

# --------------------------------------------
# EMAIL CONFIGURATION (PHPMailer)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=noreply@aurorahotelplaza.com
SMTP_FROM_NAME="Aurora Hotel Plaza"

# --------------------------------------------
# VNPAY CONFIGURATION
# --------------------------------------------
VNPAY_TMN_CODE=your_tmncode
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# --------------------------------------------
# GOOGLE OAUTH (Tùy chọn)
# --------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret